<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/output.css" />
  <title><%= title %></title>
</head>

<body class="bg-[#f0f0f0]/70 text-sm min-h-screen">

  <div class="max-w-360 w-full mx-auto px-6 py-12">

    <!-- HEADER -->
    <div class="flex items-end justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold">Products List</h1>
      </div>

      <div class="flex gap-2">
        <a href="/products/add"
          class="bg-blue-600 text-white flex! gap-1 items-center px-5 py-3 rounded-md font-semibold">
          

<?xml version="1.0" encoding="utf-8"?><!-- Uploaded to: SVG Repo, www.svgrepo.com, Generator: SVG Repo Mixer Tools -->
<svg width="23px" height="22px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M12 8V16M16 12H8M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg> Add Product
        </a>

        <a href="/products/trash"
          class="bg-amber-400 flex! gap-1 items-center px-5 py-3 rounded-md font-semibold">
         
<?xml version="1.0" encoding="utf-8"?><!-- Uploaded to: SVG Repo, www.svgrepo.com, Generator: SVG Repo Mixer Tools -->
<svg width="22px" height="20px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M3 3L21 21M18 6L17.6 12M17.2498 17.2527L17.1991 18.0129C17.129 19.065 17.0939 19.5911 16.8667 19.99C16.6666 20.3412 16.3648 20.6235 16.0011 20.7998C15.588 21 15.0607 21 14.0062 21H9.99377C8.93927 21 8.41202 21 7.99889 20.7998C7.63517 20.6235 7.33339 20.3412 7.13332 19.99C6.90607 19.5911 6.871 19.065 6.80086 18.0129L6 6H4M16 6L15.4559 4.36754C15.1837 3.55086 14.4194 3 13.5585 3H10.4416C9.94243 3 9.47576 3.18519 9.11865 3.5M11.6133 6H20M14 14V17M10 10V17" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg> Trash
        </a>
      </div>
    </div>

    <!-- TABLE HEADER -->
    <div class="grid grid-cols-10 border-t border-gray-300 rounded-lg font-semibold mb-3">
      <div class="py-4 flex justify-center">Sl No.</div>
      <div class="py-4 flex justify-center">Id</div>
      <div class="py-4 flex justify-center">Product name</div>
      <div class="py-4 flex justify-center">Size</div>
      <div class="py-4 flex justify-center">Price</div>
      <div class="py-4 flex justify-center">Color</div>
      <div class="py-4 flex justify-center">Category</div>
      <div class="py-4 flex justify-center">Desc</div>
      <div class="py-4 flex justify-center col-span-2">Action</div>
    </div>

    <!-- DATA ROWS -->
    <% data.forEach((element,index) => { %>

      <div class="grid grid-cols-10 items-center bg-white rounded-lg  mb-3">

        <div class="font-semibold flex items-center justify-center py-3">
          <%= index + 1 %>
        </div>

        <div class="font-semibold flex items-center justify-center py-3">
          <%= element._id.toString().slice(-4) %>
        </div>

        <div class="flex items-center justify-center py-3">
          <%= element.name %>
        </div>

        <div class="flex gap-1.5 items-center justify-center font-semibold py-3">
          <% element.size.forEach(s => { %>
            <span><%= s %></span>
          <% }) %>
        </div>

        <div class="flex items-center justify-center py-3">
          <%= element.price %>
        </div>

        <div class="flex items-center justify-center gap-1.5 font-semibold py-3">
          <% element.color.forEach(c => { %>
            <span><%= c %></span>
          <% }) %>
        </div>

        <div class="flex items-center justify-center py-3">
          <%= element.category %>
        </div>

        <div class="line-clamp-1 overflow-y-hidden py-3 flex justify-center items-center">
          <%= element.desc.slice(0,30) %>
        </div>

        <div class="col-span-2 flex justify-center items-center py-3 gap-2">

          <a href="/products/edit/<%= element._id %>"
            class="bg-blue-100 text-blue-600 py-2.5 px-3.5 rounded-md font-medium transform  transition-all hover:bg-blue-200">
           
<?xml version="1.0" encoding="utf-8"?><!-- Uploaded to: SVG Repo, www.svgrepo.com, Generator: SVG Repo Mixer Tools -->
<svg width="20px" height="20px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M20.8477 1.87868C19.6761 0.707109 17.7766 0.707105 16.605 1.87868L2.44744 16.0363C2.02864 16.4551 1.74317 16.9885 1.62702 17.5692L1.03995 20.5046C0.760062 21.904 1.9939 23.1379 3.39334 22.858L6.32868 22.2709C6.90945 22.1548 7.44285 21.8693 7.86165 21.4505L22.0192 7.29289C23.1908 6.12132 23.1908 4.22183 22.0192 3.05025L20.8477 1.87868ZM18.0192 3.29289C18.4098 2.90237 19.0429 2.90237 19.4335 3.29289L20.605 4.46447C20.9956 4.85499 20.9956 5.48815 20.605 5.87868L17.9334 8.55027L15.3477 5.96448L18.0192 3.29289ZM13.9334 7.3787L3.86165 17.4505C3.72205 17.5901 3.6269 17.7679 3.58818 17.9615L3.00111 20.8968L5.93645 20.3097C6.13004 20.271 6.30784 20.1759 6.44744 20.0363L16.5192 9.96448L13.9334 7.3787Z" fill="#155dfc"/>
</svg>
          </a>

          <button onclick="deleteProduct('<%= element._id %>')"
            class="bg-red-100 cursor-pointer text-red-600 py-2 px-3 rounded-md font-medium transform  transition-all hover:bg-red-200">
            
<?xml version="1.0" encoding="utf-8"?><!-- Uploaded to: SVG Repo, www.svgrepo.com, Generator: SVG Repo Mixer Tools -->
<svg width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M10 12V17" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M14 12V17" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M4 7H20" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M6 10V18C6 19.6569 7.34315 21 9 21H15C16.6569 21 18 19.6569 18 18V10" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M9 5C9 3.89543 9.89543 3 11 3H13C14.1046 3 15 3.89543 15 5V7H9V5Z" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
          </button>

        </div>

      </div>

    <% }) %>
<div id="toast"
class="fixed top-16 right-10 z-50 translate-x-full opacity-0
transition-all duration-300
bg-green-500 text-white px-5 flex items-center gap-1 py-4 rounded-md shadow-2xl font-medium">


</div>
  </div>

  <script src="/script/softDeleteScript.js"></script>

</body>
</html>