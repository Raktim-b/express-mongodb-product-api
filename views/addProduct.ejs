<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <title><%= title %></title>
  </head>

  <body class="bg-gray-100 min-h-screen ">
    <div class="max-w-360 w-full mx-auto px-6 py-12">
      <div class="max-w-1/2 mx-auto bg-white rounded-lg border border-gray-200 p-6">
        <h2 class="font-semibold text-lg mb-6">Product Details</h2>

        <form action="/products/add" method="POST" class="space-y-4">
          <div>
            <label class="text-sm text-gray-500">Product Name</label>
            <input
              name="name"
              type="text"
              required
              class="w-full border rounded-md px-3 py-2 mt-1"
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-sm text-gray-500">Price</label>
              <input
                name="price"
                type="number"
                class="w-full border rounded-md px-3 py-2 mt-1"
              />
            </div>

            <div>
              <label class="text-sm text-gray-500">Category</label>
              <input
                name="category"
                type="text"
                class="w-full border rounded-md px-3 py-2 mt-1"
              />
            </div>
          </div>

          <div>
            <label class="text-sm text-gray-500">Size</label>
            <input
              name="size"
              placeholder="S,M,L"
              class="w-full border rounded-md px-3 py-2 mt-1"
            />
          </div>

          <div>
            <label class="text-sm text-gray-500">Color</label>
            <input
              name="color"
              placeholder="Red,Black"
              class="w-full border rounded-md px-3 py-2 mt-1"
            />
          </div>

          <div>
            <label class="text-sm text-gray-500">Description</label>
            <textarea
              name="desc"
              rows="3"
              class="w-full border rounded-md px-3 py-2 mt-1"
            ></textarea>
          </div>

          <button
            class="bg-blue-600 cursor-pointer hover:bg-blue-700 text-white px-6 py-2 rounded-md"
          >
            Add Product
          </button>
        </form>
      </div>
    </div>
  </body>
</html>
